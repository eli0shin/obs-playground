{
  "name": "@obs-playground/graphql-client",
  "version": "1.0.0",
  "description": "Minimal shared GraphQL client with OpenTelemetry error recording",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./documents": {
      "types": "./dist/documents/index.d.ts",
      "default": "./dist/documents/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.32.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@obs-playground/env": "*",
    "@opentelemetry/api": "^1.9.0",
    "graphql": "^16.13.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9.38.0",
    "typescript": "^5"
  }
}
