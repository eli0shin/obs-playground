{
  "name": "obs-playground",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npx patch-package",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules && npm install",
    "dev": "bash scripts/dev.sh otel",
    "dev:dd": "bash scripts/dev.sh dd",
    "start": "bash scripts/start.sh",
    "build": "turbo run build && npm run build:custom -w nextjs-app",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint && npm run graphql:lint",
    "graphql:codegen": "graphql-codegen --config codegen.mjs",
    "graphql:codegen:watch": "graphql-codegen --config codegen.mjs --watch",
    "graphql:lint": "eslint packages/graphql-client/src/operations",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playwright": "npm run playwright:normal && npm run playwright:custom && npm run playwright:tanstack",
    "playwright:normal": "BASE_URL=${NORMAL_URL:-https://localhost} npm run test -w @obs-playground/playwright-tests",
    "playwright:custom": "BASE_URL=${CUSTOM_URL:-https://localhost:8443} npm run test -w @obs-playground/playwright-tests",
    "playwright:tanstack": "BASE_URL=${TANSTACK_URL:-https://localhost/tanstack} npm run test -w @obs-playground/playwright-tests",
    "playwright:slow": "BASE_URL=${NORMAL_URL:-https://localhost} SLOW_TESTS=true npm run test -w @obs-playground/playwright-tests",
    "playwright:repeat": "npm run test:repeat -w @obs-playground/playwright-tests"
  },
  "keywords": [],
  "author": "elimelech.oshinsky@gmail.com",
  "license": "ISC",
  "packageManager": "npm@11.5.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@types/express": "^5.0.4",
    "concurrently": "^9.2.1",
    "eslint-for-ai": "^1.0.12",
    "express": "^5.1.0",
    "graphql": "^16.13.2",
    "graphql-config": "^5.1.6",
    "http-proxy-middleware": "^3.0.5",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8"
  }
}
